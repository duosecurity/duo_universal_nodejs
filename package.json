{
  "name": "@duosecurity/duo_universal",
  "version": "2.0.3",
  "description": "Node.js implementation of the Duo Universal SDK.",
  "keywords": [
    "duo",
    "duo security"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duosecurity/duo_universal_nodejs.git"
  },
  "homepage": "https://github.com/duosecurity/duo_universal_nodejs#readme",
  "bugs": {
    "url": "https://github.com/duosecurity/duo_universal_nodejs/issues"
  },
  "packageManager": "pnpm@10.6.5",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --env.NODE_ENV production",
    "prepublishOnly": "pnpm build",
    "lint": "eslint ./src --fix",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "jose": "^6.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.13",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.0.9"
  }
}
